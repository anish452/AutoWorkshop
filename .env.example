NODE_ENV=development
PORT=3000
# A working .env is committed for team development (shared Neon PostgreSQL).
# Copy this file to .env only if you need your own database credentials.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=change-this-to-a-strong-secret-min-16-chars
JWT_EXPIRES_IN=24h
# Placeholder is fine — AI falls back to keyword classification without a real key
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=*
