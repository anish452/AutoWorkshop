    {
      "name": "Jobs",
      "item": [
        {
          "name": "POST Analyze Complaint & Create Jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const jobs = pm.response.json().data.jobs;",
                  "  if (jobs && jobs.length > 0) {",
                  "    pm.collectionVariables.set('jobId', jobs[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{advisorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleRegistrationNo\": \"ABC123\",\n  \"description\": \"My vehicle engine is making noise and the battery is not charging.\"\n}"
            },
            "url": "{{baseUrl}}/api/jobs/analyze"
          },
          "response": [
            {
              "name": "Success - Multiple Jobs Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"2 job(s) created from AI analysis\",\n  \"data\": {\n    \"analysisLog\": {\n      \"id\": \"uuid\",\n      \"reasoning\": \"Complaint contains mechanical and electrical issues\",\n      \"issues\": [\n        { \"issue\": \"Engine Noise\", \"department\": \"MECHANICAL\", \"confidence\": 0.92, \"explanation\": \"Engine noise is a mechanical issue\" },\n        { \"issue\": \"Battery Charging Problem\", \"department\": \"ELECTRICAL\", \"confidence\": 0.95, \"explanation\": \"Battery charging is electrical\" }\n      ]\n    },\n    \"jobs\": [\n      { \"jobNumber\": \"JOB-2026-00001\", \"issueDescription\": \"Engine Noise\", \"status\": \"ASSIGNED\", \"department\": { \"name\": \"Mechanical\" } },\n      { \"jobNumber\": \"JOB-2026-00002\", \"issueDescription\": \"Battery Charging Problem\", \"status\": \"ASSIGNED\", \"department\": { \"name\": \"Electrical\" } }\n    ]\n  }\n}"
            },
            {
              "name": "Error - Vehicle Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Vehicle with registration UNKNOWN not found\"\n}"
            }
          ]
        },
        {
          "name": "POST Analyze - Multilingual Complaint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{advisorToken}}" }
