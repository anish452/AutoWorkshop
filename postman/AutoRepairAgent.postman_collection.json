            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleRegistrationNo\": \"ABC123\",\n  \"description\": \"El pedal de freno está duro y los faros no funcionan.\"\n}"
            },
            "url": "{{baseUrl}}/api/jobs/analyze"
